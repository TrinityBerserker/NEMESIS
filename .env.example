# ─────────────────────────────────────────
#  NEMESIS - Variables de entorno
# ─────────────────────────────────────────

# LLM Backend (usa uno de los dos)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM Model
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-opus-4-5       # claude-opus-4-5 | gpt-4o

# LangSmith (opcional, para trazabilidad)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nemesis

# Entorno de ejecución
EXECUTION_ENV=docker             # docker | local (local = Kali host directo)
KALI_CONTAINER=nemesis-kali      # nombre del contenedor Docker Kali

# Rutas
LOG_DIR=./logs
REPORT_DIR=./reports
